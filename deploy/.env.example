# Copier ce fichier en ".env" dans deploy/ (jamais commite - deja ignore par .gitignore) et
# renseigner de vraies valeurs. Utilisation :
#   docker compose --env-file .env -f compose.prod.yml up -d
# ou simplement : ./scripts/deploy.sh (qui lit ce meme .env).

COMPOSE_PROJECT_NAME=plumora

# --- Images (construites et publiees ailleurs, ex. par la CI de chaque depot) ---
# Ne jamais utiliser uniquement ":latest" en production (voir deploy/README.md, "Images de
# production") : preferer un tag de version immuable, par exemple :
#   FRONTEND_IMAGE=ghcr.io/TON_COMPTE/plumora-frontend:v1.0.0-beta
# Backend : ce depot (plumora-api).
BACKEND_IMAGE=ghcr.io/TON_COMPTE/plumora-backend:v1.0.0
# Frontend : depot Flutter separe, non gere ici. Contrat valide : sert le build Flutter Web sur
# le port interne fixe 8080, gere son propre fallback SPA, healthcheck integre, utilisateur
# non-root (voir deploy/README.md, "Frontend Flutter Web"). Le port n'est pas configurable ici,
# il est fixe (8080) cote compose.prod.yml/Caddyfile en accord avec ce contrat.
FRONTEND_IMAGE=ghcr.io/TON_COMPTE/plumora-frontend:v1.0.0-beta

# --- PostgreSQL ---
POSTGRES_DB=plumora
POSTGRES_USER=plumora
# Obligatoire. Mot de passe fort et unique (ne jamais reutiliser une valeur de dev).
POSTGRES_PASSWORD=CHANGE_ME

# --- Backend Spring Boot ---
SPRING_PROFILES_ACTIVE=prod
# Garder le nom de base coherent avec POSTGRES_DB ci-dessus.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/plumora
SPRING_DATASOURCE_USERNAME=plumora
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# Obligatoire. Minimum 32 caracteres aleatoires. Exemple de generation : openssl rand -base64 48
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION=3600000

# Plumo IA - "mock" (aucun appel externe, aucune cle necessaire) ou "gemini" (cle obligatoire).
AI_PROVIDER=mock
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_INPUT_CHARS=12000

# Obligatoire. Origines exactes autorisees a appeler l'API, separees par des virgules.
CORS_ALLOWED_ORIGINS=https://app.plumora.fr

# --- Domaines (Caddy) ---
APP_DOMAIN=app.plumora.fr
API_DOMAIN=api.plumora.fr
WWW_DOMAIN=www.plumora.fr
# Obligatoire. Adresse utilisee par Let's Encrypt pour les notifications relatives aux
# certificats (jamais utilisee pour une quelconque authentification).
CADDY_ACME_EMAIL=admin@plumora.fr

# --- Sauvegardes ---
BACKUP_RETENTION_DAYS=14
# Optionnel : dossier de sauvegarde sur le VPS (doit exister, permissions restrictives).
# BACKUP_DIR=/var/backups/plumora/postgres
# Optionnel, pour plus tard : envoi des sauvegardes vers un bucket S3 (necessite awscli sur le
# VPS et des identifiants configures separement, jamais dans ce fichier).
# BACKUP_S3_BUCKET=
